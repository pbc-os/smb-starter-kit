# Copy to terraform.tfvars and fill in. Do NOT commit terraform.tfvars.

# --- Required ---------------------------------------------------------------
project_id = "your-lake-project-id"   # a DEDICATED project, not shared with other apps

# --- BigQuery location (pick once — permanent) ------------------------------
bq_location = "US"                     # or "EU", or a single region like "us-central1"
lake_prefix = "lake"                   # -> lake_raw, lake_clean, lake_marts, lake_archive

# --- Budget guardrail (recommended) -----------------------------------------
# Find your billing account: `gcloud billing accounts list`
billing_account   = ""                 # e.g. "000000-AAAAAA-BBBBBB"; empty = skip budget
budget_amount_usd = 50

# --- Keyless CI with Workload Identity (optional) ---------------------------
enable_github_wif = false
github_repo       = ""                 # e.g. "your-org/your-ingestion-repo" (required if enabled)
